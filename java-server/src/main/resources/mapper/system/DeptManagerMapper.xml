<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.todothink.modules.system.mapper.DeptManagerMapper">

    <select id="selectByDeptId" resultType="com.todothink.modules.system.entity.DeptManager">
        SELECT * FROM DeptManager WHERE deptId = #{deptId} ORDER BY createdAt ASC
    </select>

</mapper>
