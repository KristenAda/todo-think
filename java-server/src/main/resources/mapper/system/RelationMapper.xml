<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.todothink.modules.system.mapper.RelationMapper">

    <delete id="deleteUserRoles">
        DELETE FROM `_RoleToUser` WHERE B = #{userId}
    </delete>

    <insert id="insertUserRoles">
        INSERT INTO `_RoleToUser` (A, B) VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{roleId}, #{userId})
        </foreach>
    </insert>

    <delete id="deleteRoleMenus">
        DELETE FROM `_MenuToRole` WHERE B = #{roleId}
    </delete>

    <insert id="insertRoleMenus">
        INSERT INTO `_MenuToRole` (A, B) VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{menuId}, #{roleId})
        </foreach>
    </insert>

    <select id="selectMenuIdsByRoleId" resultType="int">
        SELECT A FROM `_MenuToRole` WHERE B = #{roleId}
    </select>

    <delete id="deleteRoleDepts">
        DELETE FROM `_RoleDepts` WHERE B = #{roleId}
    </delete>

    <insert id="insertRoleDepts">
        INSERT INTO `_RoleDepts` (A, B) VALUES
        <foreach collection="deptIds" item="deptId" separator=",">
            (#{deptId}, #{roleId})
        </foreach>
    </insert>

</mapper>
