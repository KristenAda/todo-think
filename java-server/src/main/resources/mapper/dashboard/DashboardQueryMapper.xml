<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.todothink.modules.dashboard.mapper.DashboardQueryMapper">

    <select id="sumBugCount" resultType="java.lang.Long">
        SELECT COALESCE(SUM(tc.bug_count), 0)
        FROM test_case tc
        INNER JOIN task t ON t.id = tc.task_id
        WHERE tc.qa_status = 'FAILED'
          AND (
            t.main_assignee_id = #{userId}
            <if test="coTaskIds != null and coTaskIds.size() > 0">
                OR t.id IN
                <foreach collection="coTaskIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
          )
    </select>

</mapper>
