# 数据库（示例，请按本地修改）
# DATABASE_URL="mysql://user:pass@localhost:3306/todo_think_db"

# ========== 附件上传（可选，不配置则使用代码内默认值）==========
# 上传根目录绝对路径（Windows 示例：D:/data/todo-think-uploads）
# 未设置时默认为：进程当前工作目录下的 uploads 文件夹
# UPLOAD_ROOT=

# 单个文件最大字节数（默认 104857600 = 100MB）
# UPLOAD_MAX_FILE_BYTES=104857600

# 分片上传会话过期时间（小时，默认 24）
# UPLOAD_SESSION_TTL_HOURS=24
