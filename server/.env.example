# 复制本文件为 .env 后按需修改；新人可执行 npm run setup 自动生成 .env 并初始化数据库

DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/todo_think_db"

# JWT 签名密钥（开发环境可任意长字符串；生产务必使用随机值）
JWT_SECRET="dev-change-me-to-a-long-random-string"

# ========== 附件上传（可选）==========
# UPLOAD_ROOT=
# UPLOAD_MAX_FILE_BYTES=104857600
# UPLOAD_SESSION_TTL_HOURS=24
