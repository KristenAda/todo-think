{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/app.ts",
    "dev:testdb": "node scripts/load-env-and-run.cjs .env.test npx tsx watch --clear-screen=false src/app.ts",
    "build": "node scripts/build.js",
    "build:ts": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "setup": "node scripts/db-cli.cjs setup",
    "db": "node scripts/db-cli.cjs",
    "db:test:deploy": "node scripts/run-prisma-env.cjs .env.test migrate deploy",
    "db:test:reset": "node scripts/run-prisma-env.cjs .env.test migrate reset --force --skip-seed",
    "db:test:seed": "node scripts/apply-test-seed.cjs",
    "db:test:fresh": "npm run db:test:reset && npm run db:test:seed",
    "db:test:full": "npm run db:test:fresh && npm run db:scenario:small-team",
    "db:test:comments": "node scripts/run-prisma-env.cjs .env.test migrate deploy && node scripts/load-env-and-run.cjs .env.test node scripts/prismaMysqlApplyComments.js",
    "db:test:comments:apply": "node scripts/load-env-and-run.cjs .env.test node scripts/prismaMysqlApplyComments.js",
    "db:scenario:small-team": "npx prisma generate && npx tsx scripts/seed-scenario-small-team.ts",
    "db:scenario:small-team:seed": "node scripts/load-env-and-run.cjs .env.test npx tsx scripts/seed-scenario-small-team.ts",
    "comments": "node scripts/prisma-comments-cli.cjs all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@koa/bodyparser": "^6.1.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "formidable": "^3.5.4",
    "glob": "^13.0.1",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.1.1",
    "koa-jwt": "^4.0.4",
    "koa-ratelimit": "^6.0.0",
    "mysql2": "^3.22.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/formidable": "^3.5.1",
    "@types/glob": "^8.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^3.0.1",
    "@types/koa-jwt": "^3.2.2",
    "@types/node": "^25.2.0",
    "@types/ws": "^8.18.1",
    "prisma": "^6.19.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
