// ==========================================
// 1. 用户表 (User) - user.prisma
// ==========================================
/// 用户账户表
model User {
  id        Int     @id @default(autoincrement())
  /// 登录用户名
  userName  String  @unique @map("user_name")
  /// 加密后的密码
  password  String  @map("password")
  /// 昵称
  nickName  String? @map("nick_name")
  /// 手机号
  userPhone String? @map("user_phone")
  /// 邮箱
  userEmail String? @map("user_email")
  /// 性别
  userGender String? @map("user_gender")
  /// 头像
  avatar    String? @db.LongText @map("avatar")
  /// 状态：1正常 2离线 3异常 4注销
  status    String  @default("1") @map("status")
  /// 备注
  remark    String? @map("remark")
  /// 个人标签 JSON
  tags      String? @map("tags")

  roles Role[]

  managedDepts DeptManager[] @relation("UserManagedDepts")
  memberDepts  DeptMember[]  @relation("UserMemberDepts")

  /// 创建人
  createBy  String? @map("create_by")
  /// 创建时间
  createTime DateTime @default(now()) @map("created_at")
  /// 更新人
  updateBy  String? @map("update_by")
  /// 更新时间
  updateTime DateTime @updatedAt @map("updated_at")
  /// 软删除时间
  deletedAt DateTime? @map("deleted_at")

  managedProjects   Project[]        @relation("ProjectManager")
  managedTasks      Task[]           @relation("TaskManager")
  mainAssigneeTasks Task[]           @relation("TaskMainAssignee")
  testerTasks       Task[]           @relation("TaskTester")
  coAssigneeTasks   TaskCoAssignee[] @relation("TaskCoAssignee")
  workLogs          WorkLog[]        @relation("WorkLogUser")
  taskComments      TaskComment[]    @relation("TaskCommentUser")
  taskTimelineOps   TaskTimeline[]   @relation("TaskTimelineOperator")

  attachments    Attachment[]    @relation("AttachmentUploader")
  uploadSessions UploadSession[] @relation("UploadSessionUser")

  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")

  @@map("users")
}

/// 角色表
model Role {
  id          Int     @id @default(autoincrement())
  /// 角色名称
  roleName    String  @map("role_name")
  /// 角色权限标识
  roleCode    String  @unique @map("role_code")
  /// 角色描述
  description String? @map("description")
  /// 是否启用
  enabled     Boolean @default(true) @map("enabled")
  /// 排序
  sort        Int     @default(0) @map("sort")

  /// 数据权限范围
  dataScope Int @default(1) @map("data_scope")

  /// 是否为默认角色（全局至多一个）
  isDefaultRole Boolean @default(false) @map("is_default_role")

  users User[]
  menus Menu[]

  depts Department[] @relation("RoleDepts")

  remark     String? @map("remark")
  createTime DateTime  @default(now()) @map("created_at")
  updateTime DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("roles")
}
