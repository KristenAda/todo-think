// ==========================================
// 1. 用户表 (User) - user.prisma
// ==========================================
model User {
  id        Int     @id @default(autoincrement())
  userName  String  @unique // 改名：username → userName
  password  String
  nickName  String? // 改名：nickname → nickName
  userPhone String? // 改名：phone → userPhone
  userEmail String? // 改名：email → userEmail
  userGender String? // 新增：性别 (男/女)
  avatar    String? @db.LongText // 使用 LongText 支持大型 base64 图片
  status    String  @default("1") // 改为 String：'1'正常 '2'离线 '3'异常 '4'注销
  remark    String? // 备注

  roles Role[]

  // 多对多：该用户作为管理者的部门（通过 DeptManager 关系表）
  managedDepts DeptManager[] @relation("UserManagedDepts")
  // 多对多：该用户所属的部门（通过 DeptMember 关系表）
  memberDepts  DeptMember[]  @relation("UserMemberDepts")

  createBy  String? // 新增：创建人
  createTime DateTime @default(now()) // 改名：createdAt → createTime
  updateBy  String? // 新增：更新人
  updateTime DateTime @updatedAt // 改名：updatedAt → updateTime
  deletedAt DateTime? // 软删除标志

  // ===== 任务模块反向关联 =====
  managedProjects   Project[]        @relation("ProjectManager")
  managedTasks      Task[]           @relation("TaskManager")
  mainAssigneeTasks Task[]           @relation("TaskMainAssignee")
  testerTasks       Task[]           @relation("TaskTester")
  coAssigneeTasks   TaskCoAssignee[] @relation("TaskCoAssignee")
  workLogs          WorkLog[]        @relation("WorkLogUser")
}

// ==========================================
// 2. 角色表 (Role)
// ==========================================
model Role {
  id          Int     @id @default(autoincrement())
  roleName    String  // 角色名称 (如 超级管理员)
  roleCode    String  @unique // 改名：roleKey → roleCode，角色权限标识 (如 admin)
  description String? // 新增：角色描述
  enabled     Boolean @default(true) // 改名：status → enabled，改为 Boolean
  sort        Int     @default(0) // 角色排序

  // ★★★ 数据权限核心字段 ★★★
  dataScope Int @default(1) // 1:全部数据权限 2:自定数据权限 3:本部门数据权限 4:本部门及以下数据权限 5:仅本人数据权限

  users User[]
  menus Menu[]

  // 当 dataScope=2 时，角色具体关联的部门集合 (用于自定数据权限)
  depts Department[] @relation("RoleDepts")

  remark     String?
  createTime DateTime  @default(now())
  updateTime DateTime  @updatedAt
  deletedAt  DateTime? // 软删除
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}
