// ==========================================
// 3. 菜单/权限表 (Menu)
// ==========================================
/// 菜单与权限
model Menu {
  id        Int     @id @default(autoincrement())
  parentId  Int?    @map("parent_id")
  name      String? @map("name")
  title     String  @map("title")
  path      String? @map("path")
  component String? @map("component")
  icon      String? @map("icon")
  type      Int     @default(2) @map("type")
  sort      Int     @default(0) @map("sort")

  isEnable  Boolean @default(true) @map("is_enable")
  keepAlive Boolean @default(true) @map("keep_alive")
  isIframe  Boolean @default(false) @map("is_iframe")
  isHide    Boolean @default(false) @map("is_hide")
  isHideTab Boolean @default(false) @map("is_hide_tab")
  link      String? @map("link")
  showBadge Boolean @default(false) @map("show_badge")
  showTextBadge String? @map("show_text_badge")
  fixedTab  Boolean @default(false) @map("fixed_tab")
  activePath String? @map("active_path")
  isFullPage Boolean @default(false) @map("is_full_page")
  roles     String? @map("roles")

  authList  String? @db.LongText @map("auth_list")

  roleMenus Role[]

  createTime DateTime @default(now()) @map("created_at")
  updateTime DateTime @updatedAt @map("updated_at")

  @@map("menus")
}

/// 部门表
model Department {
  id        Int     @id @default(autoincrement())
  parentId  Int?    @map("parent_id")
  ancestors String? @map("ancestors")
  name      String  @map("name")
  sort      Int     @default(0) @map("sort")
  leader    String? @map("leader")
  phone     String? @map("phone")
  email     String? @map("email")
  status    Int     @default(1) @map("status")

  managers DeptManager[]
  members  DeptMember[]
  roles    Role[] @relation("RoleDepts")

  createTime DateTime  @default(now()) @map("created_at")
  updateTime DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("departments")
}

/// 部门-管理者 关系表
model DeptManager {
  deptId    Int @map("dept_id")
  userId    Int @map("user_id")
  dept      Department @relation(fields: [deptId], references: [id])
  user      User       @relation("UserManagedDepts", fields: [userId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  @@id([deptId, userId])
  @@map("dept_managers")
}

/// 部门-成员 关系表
model DeptMember {
  deptId    Int @map("dept_id")
  userId    Int @map("user_id")
  dept      Department @relation(fields: [deptId], references: [id])
  user      User       @relation("UserMemberDepts", fields: [userId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  @@id([deptId, userId])
  @@map("dept_members")
}
