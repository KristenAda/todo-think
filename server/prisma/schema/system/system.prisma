// ==========================================
// 3. 菜单/权限表 (Menu)
// ==========================================
model Menu {
  id        Int     @id @default(autoincrement())
  parentId  Int?
  name      String? // 新增：菜单名称标识
  title     String  // 菜单显示名称
  path      String? // 路由路径
  component String? // 组件路径
  icon      String? // 菜单图标
  type      Int     @default(2) // 1:目录 2:菜单 3:按钮
  sort      Int     @default(0) // 排序

  // ★★★ 前端路由所需的元数据 ★★★
  isEnable  Boolean @default(true) // 是否启用
  keepAlive Boolean @default(true) // 是否缓存
  isIframe  Boolean @default(false) // 是否为内嵌
  isHide    Boolean @default(false) // 是否隐藏菜单
  isHideTab Boolean @default(false) // 是否隐藏标签
  link      String? // 外部链接
  showBadge Boolean @default(false) // 是否显示徽章
  showTextBadge String? // 文本徽章
  fixedTab  Boolean @default(false) // 是否固定标签
  activePath String? // 激活路径
  isFullPage Boolean @default(false) // 是否全屏页面
  roles     String? // 角色权限（JSON 数组字符串）

  // 权限列表（JSON 数组字符串，格式：[{"authMark":"add","title":"新增"}]）
  authList  String? @db.LongText

  // 关联
  roleMenus Role[]

  createTime DateTime @default(now())
  updateTime DateTime @updatedAt
}

// ==========================================
// 4. 部门表 (Department) - 更新版
// ==========================================
model Department {
  id        Int     @id @default(autoincrement())
  parentId  Int?
  ancestors String? // ★ 祖级列表 (如 "0,1,5")
  name      String
  sort      Int     @default(0)
  leader    String? // 部门负责人
  phone     String? // 联系电话
  email     String? // 邮箱
  status    Int     @default(1) // 部门状态 (1:正常 0:停用)

  // 多对多：部门管理者（通过 DeptManager 关系表）
  managers DeptManager[]
  // 多对多：部门成员（通过 DeptMember 关系表）
  members  DeptMember[]
  // 角色数据权限关联
  roles    Role[] @relation("RoleDepts")

  createTime DateTime  @default(now())
  updateTime DateTime  @updatedAt
  deletedAt  DateTime? // 软删除
}

// ==========================================
// 5. 部门-管理者 关系表 (多对多)
// ==========================================
model DeptManager {
  deptId    Int
  userId    Int
  dept      Department @relation(fields: [deptId], references: [id])
  user      User       @relation("UserManagedDepts", fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@id([deptId, userId])
}

// ==========================================
// 6. 部门-成员 关系表 (多对多)
// ==========================================
model DeptMember {
  deptId    Int
  userId    Int
  dept      Department @relation(fields: [deptId], references: [id])
  user      User       @relation("UserMemberDepts", fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@id([deptId, userId])
}
