// ==========================================
// 附件与分片上传会话（文件在磁盘，库中仅存相对路径）
// ==========================================

model Attachment {
  id           Int       @id @default(autoincrement())
  originalName String
  /// 相对上传根目录的路径，POSIX 风格，如 attachments/2026/04/xxx.pdf
  storedPath   String    @db.VarChar(1024)
  mimeType     String?   @db.VarChar(200)
  size         Int
  uploadedById Int
  uploadedBy   User      @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createTime   DateTime  @default(now())
  deletedAt    DateTime?

  uploadSession UploadSession?

  taskAttachments    TaskAttachment[]
  workLogAttachments WorkLogAttachment[]

  @@index([uploadedById])
  @@index([createTime])
  @@map("attachment")
}

/// 分片上传会话：合并完成后写入 attachmentId
model UploadSession {
  id          String   @id @default(uuid())
  fileName    String
  mimeType    String?  @db.VarChar(200)
  totalSize   Int
  chunkSize   Int
  totalChunks Int
  userId      Int
  user        User     @relation("UploadSessionUser", fields: [userId], references: [id])
  status      String   @default("pending") // pending | merged | failed | expired
  attachmentId Int?    @unique
  attachment   Attachment? @relation(fields: [attachmentId], references: [id])
  expiresAt   DateTime
  createTime  DateTime @default(now())

  @@index([userId])
  @@map("upload_session")
}
