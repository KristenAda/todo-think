model RuleSet {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(64) @map("code")
  name      String   @db.VarChar(100) @map("name")
  scope     String   @default("PROJECT") @db.VarChar(20) @map("scope")
  projectId Int? @map("project_id")
  status    String   @default("ACTIVE") @db.VarChar(20) @map("status")

  draftDefinition Json? @map("draft_definition")
  draftVariables  Json? @map("draft_variables")
  draftUpdatedAt  DateTime? @map("draft_updated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions RuleSetVersion[]

  @@index([projectId])
  @@map("rule_set")
}

model RuleSetVersion {
  id         Int      @id @default(autoincrement())
  ruleSetId  Int @map("rule_set_id")
  version    Int @map("version")
  publishedBy Int? @map("published_by")
  publishedAt DateTime @default(now()) @map("published_at")
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  checksum  String   @db.VarChar(128) @map("checksum")
  definition Json @map("definition")

  ruleSet   RuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  executions RuleExecution[]
  ledgerEntries PointsLedgerEntry[]
  perfSettlements PerfSettlement[]
  projectsUsingAsActiveScoringRule Project[] @relation("ProjectActiveScoringRule")

  @@unique([ruleSetId, version])
  @@index([ruleSetId, publishedAt])
  @@map("rule_set_version")
}

model RuleExecution {
  id              BigInt   @id @default(autoincrement())
  ruleSetVersionId Int @map("rule_set_version_id")
  triggerType     String   @db.VarChar(40) @map("trigger_type")
  triggerId       String   @db.VarChar(64) @map("trigger_id")

  status          String   @db.VarChar(20) @map("status")
  errorMessage    String?  @db.Text @map("error_message")

  inputSnapshot   Json @map("input_snapshot")
  outputSnapshot  Json? @map("output_snapshot")

  startedAt       DateTime @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")

  ruleSetVersion  RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id], onDelete: Restrict)

  @@index([ruleSetVersionId, startedAt])
  @@index([triggerType, triggerId])
  @@map("rule_execution")
}

model RuleVariable {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(64) @map("code")
  label       String   @db.VarChar(100) @map("label")
  valueType   String   @db.VarChar(20) @map("value_type")
  description String?  @db.VarChar(255) @map("description")
  sourcePath  String   @db.VarChar(100) @map("source_path")
  defaultValue Decimal? @db.Decimal(18, 6) @map("default_value")
  scope       String   @default("GLOBAL") @db.VarChar(20) @map("scope")
  projectId   Int? @map("project_id")
  enabled     Boolean  @default(true) @map("enabled")
  sort        Int      @default(0) @map("sort")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([scope, projectId, enabled, sort])
  @@map("rule_variable")
}
