model RuleSet {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(64) // 规则集标识（可用于全局/项目级）
  name      String   @db.VarChar(100)
  scope     String   @default("PROJECT") @db.VarChar(20) // GLOBAL/PROJECT
  projectId Int? // scope=PROJECT 时使用
  status    String   @default("ACTIVE") @db.VarChar(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions RuleSetVersion[]

  @@index([projectId])
  @@map("rule_set")
}

model RuleSetVersion {
  id         Int      @id @default(autoincrement())
  ruleSetId  Int
  version    Int // 规则版本号（同一 ruleSet 递增）
  publishedBy Int?
  publishedAt DateTime @default(now())
  effectiveFrom DateTime? // 生效起点（可选）
  effectiveTo   DateTime? // 生效终点（可选）

  checksum  String   @db.VarChar(128)
  definition Json // JSON DSL

  ruleSet   RuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  executions RuleExecution[]
  ledgerEntries PointsLedgerEntry[]
  perfSettlements PerfSettlement[]

  @@unique([ruleSetId, version])
  @@index([ruleSetId, publishedAt])
  @@map("rule_set_version")
}

model RuleExecution {
  id              BigInt   @id @default(autoincrement())
  ruleSetVersionId Int
  triggerType     String   @db.VarChar(40) // TaskAccepted / Adjustment / Reversal ...
  triggerId       String   @db.VarChar(64) // settlementId 等

  status          String   @db.VarChar(20) // RUNNING/SUCCEEDED/FAILED
  errorMessage    String?  @db.Text

  inputSnapshot   Json
  outputSnapshot  Json?

  startedAt       DateTime @default(now())
  endedAt         DateTime?

  ruleSetVersion  RuleSetVersion @relation(fields: [ruleSetVersionId], references: [id], onDelete: Restrict)

  @@index([ruleSetVersionId, startedAt])
  @@index([triggerType, triggerId])
  @@map("rule_execution")
}

model RuleVariable {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(64) // 变量编码，如 baseScore
  label       String   @db.VarChar(100) // 显示名称
  valueType   String   @db.VarChar(20) // Number / Float / Integer
  description String?  @db.VarChar(255)
  sourcePath  String   @db.VarChar(100) // 从 taskFact 取值路径，如 task.actualHours
  defaultValue Decimal? @db.Decimal(18, 6)
  scope       String   @default("GLOBAL") @db.VarChar(20) // GLOBAL / PROJECT
  projectId   Int?
  enabled     Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, projectId, enabled, sort])
  @@map("rule_variable")
}

