model PointsAccount {
  id        BigInt   @id @default(autoincrement())
  ownerType String   @db.VarChar(20) @map("owner_type")
  ownerId   Int @map("owner_id")
  status    String   @default("ACTIVE") @db.VarChar(20) @map("status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entries PointsLedgerEntry[]

  @@unique([ownerType, ownerId])
  @@map("points_account")
}

model PointsLedgerEntry {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt @map("account_id")

  bizType         String   @db.VarChar(30) @map("biz_type")
  bizId           String   @db.VarChar(64) @map("biz_id")

  projectId       Int? @map("project_id")
  taskId          Int? @map("task_id")

  ruleSetVersionId Int? @map("rule_set_version_id")
  pointsType      String   @db.VarChar(40) @map("points_type")
  amount          Int @map("amount")

  occurredAt      DateTime @map("occurred_at")
  createdAt       DateTime @default(now()) @map("created_at")

  idempotencyKey  String   @unique @db.VarChar(128) @map("idempotency_key")

  explain         Json? @map("explain")

  account         PointsAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  ruleSetVersion  RuleSetVersion? @relation(fields: [ruleSetVersionId], references: [id], onDelete: SetNull)
  perfItems       PerfItem[]

  @@index([bizType, bizId])
  @@index([projectId, occurredAt])
  @@index([taskId])
  @@map("points_ledger_entry")
}
