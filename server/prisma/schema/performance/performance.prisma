model PerfSettlement {
  id              BigInt   @id @default(autoincrement())
  settlementKey   String   @unique @db.VarChar(80) @map("settlement_key")
  settlementType  String   @db.VarChar(30) @map("settlement_type")

  projectId       Int @map("project_id")
  taskId          Int @map("task_id")
  occurredAt      DateTime @map("occurred_at")

  status          String   @db.VarChar(20) @map("status")
  errorMessage    String?  @db.Text @map("error_message")

  ruleSetVersionId Int? @map("rule_set_version_id")

  replacesSettlementId BigInt? @map("replaces_settlement_id")

  inputSnapshot   Json @map("input_snapshot")
  outputSnapshot  Json? @map("output_snapshot")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  settledAt       DateTime? @map("settled_at")

  items           PerfItem[]

  ruleSetVersion  RuleSetVersion? @relation(fields: [ruleSetVersionId], references: [id], onDelete: SetNull)
  replacesSettlement PerfSettlement? @relation("PerfSettlementReplace", fields: [replacesSettlementId], references: [id], onDelete: SetNull)
  replacedBy      PerfSettlement[] @relation("PerfSettlementReplace")

  @@index([taskId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([status, createdAt])
  @@map("perf_settlement")
}

model PerfItem {
  id            BigInt   @id @default(autoincrement())
  settlementId  BigInt @map("settlement_id")

  subjectType   String   @db.VarChar(20) @map("subject_type")
  subjectId     Int @map("subject_id")

  metricCode    String   @db.VarChar(40) @map("metric_code")
  value         Decimal  @db.Decimal(18, 6) @map("value")

  sourceLedgerEntryId BigInt? @map("source_ledger_entry_id")
  explain       Json? @map("explain")

  createdAt     DateTime @default(now()) @map("created_at")

  settlement    PerfSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  sourceLedgerEntry PointsLedgerEntry? @relation(fields: [sourceLedgerEntryId], references: [id], onDelete: SetNull)

  @@index([subjectType, subjectId])
  @@index([metricCode])
  @@map("perf_item")
}
