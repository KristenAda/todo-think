model PerfSettlement {
  id              BigInt   @id @default(autoincrement())
  settlementKey   String   @unique @db.VarChar(80) // 幂等键：taskId + type + acceptedAt 等
  settlementType  String   @db.VarChar(30) // first/adjustment/reversal

  projectId       Int
  taskId          Int
  occurredAt      DateTime // 业务发生时间（验收通过/冲正发生）

  status          String   @db.VarChar(20) // PENDING/RUNNING/SUCCEEDED/FAILED
  errorMessage    String?  @db.Text

  ruleSetVersionId Int?

  replacesSettlementId BigInt? // adjustment/reversal 指向被替代的结算

  inputSnapshot   Json
  outputSnapshot  Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  settledAt       DateTime?

  items           PerfItem[]

  ruleSetVersion  RuleSetVersion? @relation(fields: [ruleSetVersionId], references: [id], onDelete: SetNull)
  replacesSettlement PerfSettlement? @relation("PerfSettlementReplace", fields: [replacesSettlementId], references: [id], onDelete: SetNull)
  replacedBy      PerfSettlement[] @relation("PerfSettlementReplace")

  @@index([taskId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([status, createdAt])
  @@map("perf_settlement")
}

model PerfItem {
  id            BigInt   @id @default(autoincrement())
  settlementId  BigInt

  subjectType   String   @db.VarChar(20) // USER/TEAM
  subjectId     Int

  metricCode    String   @db.VarChar(40) // points_total / quality_score / ...
  value         Decimal  @db.Decimal(18, 6)

  sourceLedgerEntryId BigInt?
  explain       Json?

  createdAt     DateTime @default(now())

  settlement    PerfSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  sourceLedgerEntry PointsLedgerEntry? @relation(fields: [sourceLedgerEntryId], references: [id], onDelete: SetNull)

  @@index([subjectType, subjectId])
  @@index([metricCode])
  @@map("perf_item")
}

