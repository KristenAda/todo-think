// ============================================================
// 任务与研发效能管理系统 — Prisma Schema
// ============================================================

// 👉 【新增】任务类型枚举
enum TaskType {
  FEATURE // 需求
  BUG // 缺陷
  CHORE // 技术债/杂项
  ENHANCEMENT // 优化
}

/// 任务领域（仅 SOFTWARE_DEVELOPMENT 启用测试用例与提测/验收）
enum TaskWorkDomain {
  SOFTWARE_DEVELOPMENT // 软件开发
  PRODUCT_DESIGN // 产品与设计
  OPERATIONS_SUPPORT // 运维与实施
  DATA_ANALYTICS // 数据分析
  GENERAL // 综合与其他
}

// 任务优先级
enum TaskPriority {
  P0 // 紧急/最高
  P1 // 高
  P2 // 中
  P3 // 低
}

/// 任务难度档位（映射绩效公式 complexity 系数；创建/编辑选用档位，系统写入 complexity 冗余字段）
enum TaskComplexityTier {
  SIMPLE // 简单 → 0.8
  STANDARD // 常规 → 1.0
  COMPLEX // 复杂 → 1.2
  VERY_HARD // 极难 → 1.5
}

/// 任务状态
enum TaskStatus {
  PENDING // 待分配/待开发
  IN_PROGRESS // 开发中
  SELF_TESTING // 待提测
  QA_REVIEW // 验收中
  REJECTED // 打回修改
  COMPLETED // 已完成
  PAUSED // 👉 【新增状态】已暂停
  CANCELLED // 👉 【新增状态】已取消
}

/// 测试用例执行状态
enum TestStatus {
  UNTESTED // 未测试
  PASSED // 通过
  FAILED // 失败
}

/// 项目表
model Project {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100) // 项目名称
  description String? @db.Text // 项目描述

  // 👉 【统一新增的字段】
  orgId   Int? // 归属部门/组织ID（解决数据隔离；nullable：无法确定时设为 null）
  version Int @default(0) // 乐观锁版本号

  managerId  Int // 负责人ID
  status     String    @default("ACTIVE") @db.VarChar(20)
  startDate  DateTime? // 计划开始时间
  endDate    DateTime? // 计划结束时间
  createTime DateTime  @default(now())
  updateTime DateTime  @updatedAt
  deletedAt  DateTime? // 软删除

  manager User   @relation("ProjectManager", fields: [managerId], references: [id])
  taskRule ProjectTaskRule?
  tasks   Task[]

  /// 用户指定的验收计分生效规则版本（结算优先使用；为空则按规则集自动择优）
  activeRuleSetVersionId Int?
  activeRuleSetVersion   RuleSetVersion? @relation("ProjectActiveScoringRule", fields: [activeRuleSetVersionId], references: [id], onDelete: SetNull)

  @@index([orgId, id])
  @@map("project")
}

/// 项目级任务流转规则（配置化：用于流程治理主线B）
model ProjectTaskRule {
  id        Int     @id @default(autoincrement())
  projectId Int    @unique

  // 规则开关（默认值保持“当前系统行为不变”）
  requireEstimateHours Boolean @default(false)
  requireDueDate Boolean @default(false)
  requireTestEvidenceForDev Boolean @default(true)
  allowCoAssigneeSubmitQa Boolean @default(false)
  allowQaRejectWithoutHours Boolean @default(true)

  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_task_rule")
}

/// 任务表
model Task {
  id        Int @id @default(autoincrement())
  projectId Int // 所属项目

  // 👉 【统一新增的核心业务与安全字段】
  orgId    Int? // 归属部门/组织ID（冗余提升查询性能；nullable：无法确定时设为 null）
  version  Int          @default(0) // 乐观锁版本号
  parentId Int? // 父任务ID（支持需求拆解）
  type       TaskType       @default(FEATURE) // 事项类型（需求/缺陷等）
  workDomain TaskWorkDomain @default(GENERAL) // 任务领域（仅软件开发可走测试用例）
  priority   TaskPriority   @default(P2) // 任务优先级
  dueDate  DateTime? // 计划完成/截止时间

  title       String     @db.VarChar(200) // 任务名称
  description String?    @db.Text // 任务描述
  status      TaskStatus @default(PENDING) // 任务状态

  // 人员关联
  managerId      Int? // 分配者/管理者ID
  mainAssigneeId Int? // 主要负责人ID
  testerId       Int? // 测试验收人ID

  // 工时
  estimatedHours Float? // 预期工时（小时）
  actualHours    Float? // 实际工时（小时）
  suggestedBaseScore Float? // 系统建议基础积分（由任务信息估算）
  baseScore Float? // 最终基础积分（用于结算）
  baseScoreSource String @default("AUTO") @db.VarChar(20) // AUTO / MANUAL
  /** 难度档位；绩效结算按档位映射系数，见 TaskComplexityTier */
  complexityTier TaskComplexityTier @default(STANDARD)
  /// 与 complexityTier 对应的系数冗余（规则变量 task.complexity），由应用层同步
  complexity       Float  @default(1)
  qaRejectReason String? @db.Text // 最近一次验收打回原因（任务级）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  acceptedAt DateTime? // 验收通过时间（业务发生时间；用于绩效账期归属）

  // 关联关系
  project Project @relation(fields: [projectId], references: [id])

  // 👉 【新增】父子任务关联
  parent   Task?  @relation("TaskHierarchy", fields: [parentId], references: [id])
  children Task[] @relation("TaskHierarchy")

  manager      User? @relation("TaskManager", fields: [managerId], references: [id])
  mainAssignee User? @relation("TaskMainAssignee", fields: [mainAssigneeId], references: [id])
  tester       User? @relation("TaskTester", fields: [testerId], references: [id])

  coAssignees TaskCoAssignee[]
  testCases   TestCase[]
  workLogs    WorkLog[]
  comments    TaskComment[]
  timelines   TaskTimeline[]
  attachments TaskAttachment[]

  @@index([orgId, id])
  @@index([projectId, status, id])
  @@index([mainAssigneeId, id])
  @@map("task")
}

/// 任务协助负责人中间表（多对多）
model TaskCoAssignee {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskCoAssignee", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@map("task_co_assignee")
}

/// 测试用例表
model TestCase {
  id             Int    @id @default(autoincrement())
  taskId         Int // 所属任务
  description    String @db.Text // 用例描述/操作步骤
  expectedResult String @db.Text // 预期结果

  // 自测
  selfTestStatus TestStatus @default(UNTESTED) // 开发者自测状态
  selfTestRemark String?    @db.Text // 自测备注

  // QA 验收
  qaStatus TestStatus @default(UNTESTED) // QA 验收状态
  qaRemark String?    @db.Text // QA 备注
  bugCount Int        @default(0) // 累计 Bug 次数

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("test_case")
}

/// 工时与动态记录表
model WorkLog {
  id        Int      @id @default(autoincrement())
  taskId    Int // 所属任务
  userId    Int // 填报人
  hours     Float // 本次消耗工时（小时）
  content   String   @db.Text // 工作内容描述
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("WorkLogUser", fields: [userId], references: [id])

  attachments WorkLogAttachment[]

  @@map("work_log")
}

/// 任务级附件（创建任务时关联，挂在任务下）
model TaskAttachment {
  id           Int @id @default(autoincrement())
  taskId       Int
  attachmentId Int
  sort         Int @default(0)
  createdAt    DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([taskId, attachmentId])
  @@index([attachmentId])
  @@map("task_attachment")
}

/// 工时登记附件
model WorkLogAttachment {
  id           Int @id @default(autoincrement())
  workLogId    Int
  attachmentId Int
  sort         Int @default(0)
  createdAt    DateTime @default(now())

  workLog    WorkLog    @relation(fields: [workLogId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([workLogId, attachmentId])
  @@index([attachmentId])
  @@map("work_log_attachment")
}

/// 任务评论
model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task        Task                    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User                    @relation("TaskCommentUser", fields: [userId], references: [id])
  attachments TaskCommentAttachment[]

  @@index([taskId, createdAt])
  @@map("task_comment")
}

/// 任务评论附件
model TaskCommentAttachment {
  id           Int      @id @default(autoincrement())
  commentId    Int
  attachmentId Int
  sort         Int      @default(0)
  createdAt    DateTime @default(now())

  comment    TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  attachment Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([commentId, attachmentId])
  @@index([attachmentId])
  @@map("task_comment_attachment")
}

/// 任务时间线事件
model TaskTimeline {
  id          Int      @id @default(autoincrement())
  taskId       Int
  eventType    String   @db.VarChar(40)
  title        String   @db.VarChar(120)
  content      String?  @db.Text
  fromStatus   TaskStatus?
  toStatus     TaskStatus?
  operatorId   Int?
  payload      Json?
  createdAt    DateTime @default(now())

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  operator  User? @relation("TaskTimelineOperator", fields: [operatorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_timeline")
}
