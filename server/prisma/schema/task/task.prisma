// ============================================================
// 任务与研发效能管理系统 — Prisma Schema
// ============================================================

// 👉 【新增】任务类型枚举
enum TaskType {
  FEATURE // 需求
  BUG // 缺陷
  CHORE // 技术债/杂项
  ENHANCEMENT // 优化
}

/// 任务领域（仅 SOFTWARE_DEVELOPMENT 启用测试用例与提测/验收）
enum TaskWorkDomain {
  SOFTWARE_DEVELOPMENT // 软件开发
  PRODUCT_DESIGN // 产品与设计
  OPERATIONS_SUPPORT // 运维与实施
  DATA_ANALYTICS // 数据分析
  GENERAL // 综合与其他
}

// 任务优先级
enum TaskPriority {
  P0 // 紧急/最高
  P1 // 高
  P2 // 中
  P3 // 低
}

/// 任务难度档位（映射绩效公式 complexity 系数；创建/编辑选用档位，系统写入 complexity 冗余字段）
enum TaskComplexityTier {
  SIMPLE // 简单 → 0.8
  STANDARD // 常规 → 1.0
  COMPLEX // 复杂 → 1.2
  VERY_HARD // 极难 → 1.5
}

/// 任务状态
enum TaskStatus {
  PENDING // 待分配/待开发
  IN_PROGRESS // 开发中
  SELF_TESTING // 待提测
  QA_REVIEW // 验收中
  REJECTED // 打回修改
  COMPLETED // 已完成
  PAUSED // 👉 【新增状态】已暂停
  CANCELLED // 👉 【新增状态】已取消
}

/// 测试用例执行状态
enum TestStatus {
  UNTESTED // 未测试
  PASSED // 通过
  FAILED // 失败
}

/// 项目表
model Project {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100) // 项目名称
  description String? @db.Text // 项目描述

  // 👉 【统一新增的字段】
  orgId   Int? @map("org_id")
  version Int @default(0) @map("version")

  managerId  Int @map("manager_id")
  status     String    @default("ACTIVE") @db.VarChar(20) @map("status")
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  createTime DateTime  @default(now()) @map("created_at")
  updateTime DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  manager User   @relation("ProjectManager", fields: [managerId], references: [id])
  taskRule ProjectTaskRule?
  tasks   Task[]

  /// 用户指定的验收计分生效规则版本（结算优先使用；为空则按规则集自动择优）
  activeRuleSetVersionId Int? @map("active_rule_set_version_id")
  activeRuleSetVersion   RuleSetVersion? @relation("ProjectActiveScoringRule", fields: [activeRuleSetVersionId], references: [id], onDelete: SetNull)

  @@index([orgId, id])
  @@map("project")
}

/// 项目级任务流转规则（配置化：用于流程治理主线B）
model ProjectTaskRule {
  id        Int     @id @default(autoincrement())
  projectId Int    @unique @map("project_id")

  requireEstimateHours Boolean @default(false) @map("require_estimate_hours")
  requireDueDate Boolean @default(false) @map("require_due_date")
  requireTestEvidenceForDev Boolean @default(true) @map("require_test_evidence_for_dev")
  allowCoAssigneeSubmitQa Boolean @default(false) @map("allow_co_assignee_submit_qa")
  allowQaRejectWithoutHours Boolean @default(true) @map("allow_qa_reject_without_hours")

  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_task_rule")
}

/// 任务表
model Task {
  id        Int @id @default(autoincrement())
  projectId Int @map("project_id")

  orgId    Int? @map("org_id")
  version  Int          @default(0) @map("version")
  parentId Int? @map("parent_id")
  type       TaskType       @default(FEATURE) @map("type")
  workDomain TaskWorkDomain @default(GENERAL) @map("work_domain")
  priority   TaskPriority   @default(P2) @map("priority")
  dueDate  DateTime? @map("due_date")

  title       String     @db.VarChar(200) @map("title")
  description String?    @db.Text @map("description")
  status      TaskStatus @default(PENDING) @map("status")

  managerId      Int? @map("manager_id")
  mainAssigneeId Int? @map("main_assignee_id")
  testerId       Int? @map("tester_id")

  estimatedHours Float? @map("estimated_hours")
  actualHours    Float? @map("actual_hours")
  suggestedBaseScore Float? @map("suggested_base_score")
  baseScore Float? @map("base_score")
  baseScoreSource String @default("AUTO") @db.VarChar(20) @map("base_score_source")
  complexityTier TaskComplexityTier @default(STANDARD) @map("complexity_tier")
  complexity       Float  @default(1) @map("complexity")
  qaRejectReason String? @db.Text @map("qa_reject_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  acceptedAt DateTime? @map("accepted_at")

  // 关联关系
  project Project @relation(fields: [projectId], references: [id])

  // 👉 【新增】父子任务关联
  parent   Task?  @relation("TaskHierarchy", fields: [parentId], references: [id])
  children Task[] @relation("TaskHierarchy")

  manager      User? @relation("TaskManager", fields: [managerId], references: [id])
  mainAssignee User? @relation("TaskMainAssignee", fields: [mainAssigneeId], references: [id])
  tester       User? @relation("TaskTester", fields: [testerId], references: [id])

  coAssignees TaskCoAssignee[]
  testCases   TestCase[]
  workLogs    WorkLog[]
  comments    TaskComment[]
  timelines   TaskTimeline[]
  attachments TaskAttachment[]

  @@index([orgId, id])
  @@index([projectId, status, id])
  @@index([mainAssigneeId, id])
  @@map("task")
}

/// 任务协助负责人中间表（多对多）
model TaskCoAssignee {
  id        Int      @id @default(autoincrement())
  taskId    Int @map("task_id")
  userId    Int @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskCoAssignee", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@map("task_co_assignee")
}

/// 测试用例表
model TestCase {
  id             Int    @id @default(autoincrement())
  taskId         Int @map("task_id")
  description    String @db.Text @map("description")
  expectedResult String @db.Text @map("expected_result")

  selfTestStatus TestStatus @default(UNTESTED) @map("self_test_status")
  selfTestRemark String?    @db.Text @map("self_test_remark")

  qaStatus TestStatus @default(UNTESTED) @map("qa_status")
  qaRemark String?    @db.Text @map("qa_remark")
  bugCount Int        @default(0) @map("bug_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("test_case")
}

/// 工时与动态记录表
model WorkLog {
  id        Int      @id @default(autoincrement())
  taskId    Int @map("task_id")
  userId    Int @map("user_id")
  hours     Float @map("hours")
  content   String   @db.Text @map("content")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("WorkLogUser", fields: [userId], references: [id])

  attachments WorkLogAttachment[]

  @@map("work_log")
}

/// 任务级附件（创建任务时关联，挂在任务下）
model TaskAttachment {
  id           Int @id @default(autoincrement())
  taskId       Int @map("task_id")
  attachmentId Int @map("attachment_id")
  sort         Int @default(0) @map("sort")
  createdAt    DateTime @default(now()) @map("created_at")

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([taskId, attachmentId])
  @@index([attachmentId])
  @@map("task_attachment")
}

/// 工时登记附件
model WorkLogAttachment {
  id           Int @id @default(autoincrement())
  workLogId    Int @map("work_log_id")
  attachmentId Int @map("attachment_id")
  sort         Int @default(0) @map("sort")
  createdAt    DateTime @default(now()) @map("created_at")

  workLog    WorkLog    @relation(fields: [workLogId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([workLogId, attachmentId])
  @@index([attachmentId])
  @@map("work_log_attachment")
}

/// 任务评论
model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int @map("task_id")
  userId    Int @map("user_id")
  content   String   @db.Text @map("content")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task        Task                    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User                    @relation("TaskCommentUser", fields: [userId], references: [id])
  attachments TaskCommentAttachment[]

  @@index([taskId, createdAt])
  @@map("task_comment")
}

/// 任务评论附件
model TaskCommentAttachment {
  id           Int      @id @default(autoincrement())
  commentId    Int      @map("comment_id")
  attachmentId Int      @map("attachment_id")
  sort         Int      @default(0) @map("sort")
  createdAt    DateTime @default(now()) @map("created_at")

  comment    TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  attachment Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([commentId, attachmentId])
  @@index([attachmentId])
  @@map("task_comment_attachment")
}

/// 任务时间线事件
model TaskTimeline {
  id          Int      @id @default(autoincrement())
  taskId       Int @map("task_id")
  eventType    String   @db.VarChar(40) @map("event_type")
  title        String   @db.VarChar(120) @map("title")
  content      String?  @db.Text @map("content")
  fromStatus   TaskStatus? @map("from_status")
  toStatus     TaskStatus? @map("to_status")
  operatorId   Int? @map("operator_id")
  payload      Json? @map("payload")
  createdAt    DateTime @default(now()) @map("created_at")

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  operator  User? @relation("TaskTimelineOperator", fields: [operatorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_timeline")
}
