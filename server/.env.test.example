# 复制本文件为 .env.test（server 目录，已被 .gitignore 忽略）后修改连接串。
# 用途：连接「测试专用 MySQL 库」，与日常开发的 .env（DATABASE_URL → todo_think_db）分离。
#
# 切换方式（均在 server 目录）：
#   - 跑后端连测试库：npm run dev:testdb
#   - 清空测试库并重灌最小权限种子（推荐）：npm run db:test:fresh
#       · 等价 CLI：npm run db -- test-fresh
#       · 含「研发部 7 人」场景数据：npm run db:test:full（= fresh + db:scenario:small-team）
#   - 仅删数据重建表结构（不灌种子）：npm run db:test:reset
#   - 不删数据、只补迁移：npm run db:test:deploy
#   - 与仓库迁移 + Prisma /// 注释对齐测试库：npm run db:test:comments
#   - 仅同步 COMMENT：npm run db:test:comments:apply
#   - dev:testdb 已启动导致 prisma generate 报 EPERM 时，场景数据可：npm run db:scenario:small-team:seed
#   - 仅在空库或已从备份清空后灌种子：npm run db:test:seed（否则请用 db:test:fresh）
#
# 初次搭建测试库建议顺序：
#   1. MySQL：CREATE DATABASE todo_think_test_db CHARACTER SET utf8mb4 ...
#   2. 复制本文件为 .env.test，配置 DATABASE_URL
#   3. npm run db:test:fresh（migrate reset + todo_think_test_seed.sql）
#   4. （可选）npm run db:scenario:small-team — 若上一步未用 db:test:full
#
# 注意：库名须含 test（例如 todo_think_test_db），勿填 todo_think_db。
# Cursor/终端有时已注入 DATABASE_URL；db:test:seed 与 scenario 脚本会以 .env.test 覆盖之。

DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/todo_think_test_db"

# 与开发环境保持一致即可（勿提交真实生产密钥）
JWT_SECRET="dev-change-me-to-a-long-random-string"
